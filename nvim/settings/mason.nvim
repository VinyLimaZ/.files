lua << EOF
require("mason").setup()

require("mason-lspconfig").setup({
  ensure_installed = {
    "solargraph",
    "lua_ls",
  },
})

-- Lua
vim.lsp.config("lua_ls", {
  settings = {
    Lua = {
      diagnostics = {
        globals = { "vim" },
      },
    },
  },
})

-- Ruby
vim.lsp.config("solargraph", {
  settings = {
    solargraph = {
      diagnostics = true,
    },
  },
})
EOF
